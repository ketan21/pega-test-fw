{
  "name": "pega-test-framework",
  "version": "1.0.0",
  "description": "Playwright API + UI test automation framework for Pega applications",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep '@smoke'",
    "test:api": "playwright test --grep '@api'",
    "test:ui-test": "playwright test --grep '@ui'",
    "test:constellation": "playwright test --grep '@constellation'",
    "test:traditional": "playwright test --grep '@traditional'",
    "test:regression": "playwright test --grep '@regression'",
    "test:e2e": "playwright test --grep '@e2e'",
    "test:report": "playwright show-report",
    "test:allure": "allure generate ./reports/allure-results --clean -o ./reports/allure-report && allure open ./reports/allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.ts'",
    "format:check": "prettier --check '**/*.ts'",
    "prepare": "husky",
    "ci:install": "npx playwright install --with-deps chromium firefox webkit"
  },
  "keywords": [
    "playwright",
    "pega",
    "test-automation",
    "e2e",
    "api-testing"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.13.0",
    "allure-playwright": "^3.2.0",
    "eslint": "^9.21.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
